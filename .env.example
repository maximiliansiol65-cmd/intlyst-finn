# ════════════════════════════════════════════════════════════
# INTLYST Environment Configuration - EXAMPLE
# ════════════════════════════════════════════════════════════
# 
# Usage:
# 1. Copy this file: cp .env.example .env.local (for development)
#                    cp .env.example .env.production (for production)
# 2. Replace all [...] placeholders with actual values
# 3. NEVER COMMIT the .env files with real secrets
# 4. For production, use environment variables instead
#
# ════════════════════════════════════════════════════════════

# 🤖 AI / Claude Configuration
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-[GENERATE-FROM-ANTHROPIC-CONSOLE]
CLAUDE_MODEL=claude-sonnet-4-20250514

# 🗺️ Google Maps Configuration
# Get your API key from: https://console.cloud.google.com/
# Make sure these APIs are enabled:
# - Maps JavaScript API
# - Geocoding API
# - Maps Static API
GOOGLE_MAPS_API_KEY=AIzaSy[GENERATE-FROM-GOOGLE-CLOUD-CONSOLE]
GOOGLE_ANALYTICS_PROPERTY_ID=[OPTIONAL-GA4-PROPERTY-ID]
GOOGLE_ANALYTICS_KEY=[OPTIONAL-GA4-KEY]

# 💳 Stripe Configuration
# Get your keys from: https://dashboard.stripe.com/
# IMPORTANT: Use sk_test_... for development, sk_live_... for production
STRIPE_SECRET_KEY=sk_test_...[REPLACE-WITH-YOUR-KEY]
STRIPE_WEBHOOK_SECRET=whsec_...[GENERATE-FROM-WEBHOOK-SETTINGS]

# Stripe Product Prices (from https://dashboard.stripe.com/products)
STRIPE_PRICE_STANDARD=price_[GENERATE-FROM-STRIPE]
STRIPE_PRICE_TEAM_STANDARD=price_[GENERATE-FROM-STRIPE]
STRIPE_PRICE_TEAM_PRO=price_[GENERATE-FROM-STRIPE]

# 🔐 Security & Authentication
# JWT Secret: Generate a strong 32+ byte secret
# Production: Use `openssl rand -base64 32`
# DO NOT use: bizlytics-super-secret-key-change-in-production (DEFAULT DEV KEY)
JWT_SECRET=[GENERATE-STRONG-SECRET-AT-LEAST-32-BYTES]

# Webhook Security Secret
# Generate: `openssl rand -hex 32`
WEBHOOK_SECRET=[GENERATE-WEBHOOK-SECRET]

# 🌐 CORS Configuration (Production ONLY)
# Set to your actual domain(s) where the frontend runs
# Development: Use default localhost:5173, localhost:3000
# Production: https://intlyst.example.com,https://app.intlyst.example.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# 📧 Email Configuration (Optional)
# For sending alerts and notifications
SMTP_SERVER=[OPTIONAL-SMTP-SERVER]
SMTP_PORT=587
SMTP_USERNAME=[OPTIONAL-SMTP-USERNAME]
SMTP_PASSWORD=[OPTIONAL-SMTP-PASSWORD]
SENDER_EMAIL=[OPTIONAL-SENDER-EMAIL]

# 📊 HubSpot Integration (Optional)
HUBSPOT_API_KEY=[OPTIONAL-HUBSPOT-KEY]

# 🗄️ Database Configuration (if using external DB)
# For development: Uses SQLite (local.db)
# For production: Configure external database
DATABASE_URL=sqlite:///./local.db

# 📝 Logging & Environment
LOG_LEVEL=INFO
DEBUG=False  # NEVER set to True in production

# 🚀 Application Environment
APP_ENV=development  # development | staging | production
APP_NAME=INTLYST Dashboard
API_VERSION=0.25.0

# 🔔 Monitoring & Observability (Optional)
# Sentry error tracking
SENTRY_DSN=[OPTIONAL-SENTRY-DSN]

# 📊 Analytics (Optional)
# DataDog, New Relic, etc.
DATADOG_API_KEY=[OPTIONAL-DATADOG-KEY]

# ════════════════════════════════════════════════════════════
# SECURITY NOTES
# ════════════════════════════════════════════════════════════
#
# 1. PRODUCTION CHECKLIST:
#    ✓ All [...] placeholders must be replaced
#    ✓ JWT_SECRET must be strong (32+ bytes)
#    ✓ Use HTTPS URLs everywhere
#    ✓ Rotate API keys regularly
#    ✓ Use environment variables, NOT .env files
#    ✓ Enable rate limiting (see SECURITY_OPTIMIZATION_REPORT.md)
#    ✓ Set ALLOWED_ORIGINS to your production domain
#
# 2. SENSITIVE KEYS (NEVER COMMIT):
#    - ANTHROPIC_API_KEY (costs money if exposed)
#    - STRIPE_SECRET_KEY (can charge customers)
#    - JWT_SECRET (can forge authentication tokens)
#    - WEBHOOK_SECRET (can spoof Stripe webhooks)
#    - GOOGLE_MAPS_API_KEY (can be rate limited on your quota)
#
# 3. ROTATION SCHEDULE:
#    ✓ API Keys: Every 90 days
#    ✓ JWT Secret: After any suspected breach
#    ✓ Webhook Secrets: When rotating Stripe webhooks
#    ✓ Database passwords: Every 90 days
#
# 4. DEVELOPMENT SETUP:
#    cp .env.example .env.local
#    source .env.local  # Load environment variables
#    python main.py     # Start development server
#
# 5. PRODUCTION DEPLOYMENT:
#    Use environment variables instead of .env:
#    docker run \
#      -e ANTHROPIC_API_KEY="sk-ant-..." \
#      -e JWT_SECRET="..." \
#      -e STRIPE_SECRET_KEY="sk_live_..." \
#      intlyst-api
#
# ════════════════════════════════════════════════════════════
